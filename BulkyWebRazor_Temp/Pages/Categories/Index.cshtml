@page
@model BulkyWebRazor_Temp.Pages.Categories.IndexModel

    <div class="container">
        <div class="row pt-4 pb-3">
            <div class="col-6">
                <h2 class="text-primary">
                    Category list
                </h2>
            </div>
            <div class="col-6 text-end">
                <a asp-page="/categories/create" class="btn btn-primary">
                <i class="bi bi-file-plus"></i>Create new category
                </a>
            </div>
        </div>
<h1>Category list</h1>
<table class="table table-bordered table-striped">
    <thead>
    <tr>
        <th>
            Category Name 
        </th>
        <th>
            Display Order
        </th>
        <th></th>
    </tr>
    </thead>
    <tbody>
        @foreach(var item in Model.CategoryList.OrderBy(u=>u.DisplayOrder))
    {
        <tr>
            <td>
                @item.Name
            </td>
            <td>
                @item.DisplayOrder
            </td>
            <td>
                <div class="w-75 btn-group" role="group">
                    <a asp-page="/categories/edit" asp-route-id="@item.Id" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil-square"></i>Edit
                    </a>
                            <a asp-page="/categories/delete" asp-route-id="@item.Id" class="btn btn-primary mx-2">
                                <i class="bi bi-trash-fill"></i>Delete
                            </a>
                </div>
            </td>
        </tr>
    }
</table>
    </div>
